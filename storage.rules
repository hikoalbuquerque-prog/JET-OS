rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de ocorrências — qualquer usuário autenticado pode ler e escrever
    match /ocorrencias/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // max 10MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Fotos de estações — qualquer usuário autenticado
    match /estacoes/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Uploads de tarefas logísticas
    match /tarefas/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Notas fiscais dos prestadores
    match /notas_fiscais/{uid}/{arquivo} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.token.email.matches('.*@jetshr.*'));
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('(image/.*|application/pdf)');
    }

    // Fotos gerais — qualquer pasta
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024;
    }
  }
}
