rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNÇÕES AUXILIARES ────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAtivo() {
      return isAuth() && (
        getUser().get('ativo', false) == true ||
        getUser().get('role', '') in
          ['admin', 'gestor', 'supergestor', 'gestor_seg', 'campo', 'guard',
           'promotor', 'viewer', 'logistica', 'charger', 'scalt']
      );
    }

    function hasRole(roles) {
      return isAtivo() && getUser().get('role', '') in roles;
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    function isGestor() {
      return hasRole(['admin', 'gestor']);
    }

    function isSuperGestor() {
      return hasRole(['admin', 'supergestor']);
    }

    function isGestorSeg() {
      return hasRole(['admin', 'gestor', 'supergestor', 'gestor_seg']);
    }

    function isViewer() {
      return hasRole(['viewer']);
    }

    function isCampo() {
      return hasRole(['campo', 'promotor', 'charger', 'scalt']);
    }

    function isPrestadorAtivo() {
      return isAuth() && getUser().get('statusPrestador', '') == 'ativo';
    }

    // ── USUÁRIOS ──────────────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isGestorSeg() || isSuperGestor());
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == uid || isGestorSeg() || isSuperGestor());
      allow delete: if isAdmin();
    }

    // ── LOGS ACESSO ───────────────────────────────────────────────────
    match /logs_acesso/{id} {
      allow write: if isAuth();
      allow read:  if isGestor();
    }

    // ── CONSENTIMENTOS LGPD ───────────────────────────────────────────
    // Registro auditável e IMUTÁVEL do aceite de rastreamento (segurança jurídica).
    // id = "{uid}_v{versao}". Cada usuário só cria/lê o próprio; gestão lê todos.
    match /consentimentos_lgpd/{id} {
      allow get:    if isAuth(); // usuário consulta o próprio aceite (id contém o uid)
      allow list:   if isGestorSeg();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // imutável — prova do consentimento
    }

    // ── PRESTADORES FISCAL (NFS-e) ────────────────────────────────────
    // Dados fiscais do prestador (MEI) p/ emissão automática de NFS-e.
    // Espelha a RLS do Supabase (prestadores_fiscal): o prestador edita só os
    // campos AUTO-DECLARADOS; os sensíveis (alíquota/código de serviço/status da
    // procuração/faturamento/nº DPS) são definidos por gestor/Edge Fn — o prestador
    // não pode alterá-los. id do doc = uid.
    match /prestadores_fiscal/{uid} {
      // Em um update do próprio prestador, os campos sensíveis devem ficar idênticos.
      function fiscalSensiveisIntactos() {
        return request.resource.data.get('codigo_servico', null)    == resource.data.get('codigo_servico', null)
            && request.resource.data.get('aliquota_iss', null)      == resource.data.get('aliquota_iss', null)
            && request.resource.data.get('municipio_incidencia', null) == resource.data.get('municipio_incidencia', null)
            && request.resource.data.get('procuracao_status', null) == resource.data.get('procuracao_status', null)
            && request.resource.data.get('faturamento_ano', null)   == resource.data.get('faturamento_ano', null)
            && request.resource.data.get('ultimo_ndps', null)       == resource.data.get('ultimo_ndps', null);
      }
      allow read:   if isAuth() && (request.auth.uid == uid || isGestorSeg());
      allow create: if isGestor() || (isAuth() && request.auth.uid == uid);
      allow update: if isGestor() || (isAuth() && request.auth.uid == uid && fiscalSensiveisIntactos());
      allow delete: if isGestor();
    }

    // ── ESTAÇÕES ──────────────────────────────────────────────────────
    match /estacoes/{id} {
      allow read:   if isAtivo();
      allow create: if isGestor() || isSuperGestor() || isCampo();
      allow update: if isGestor() || isSuperGestor() || isCampo();
      allow delete: if isGestor() || isSuperGestor();
    }

    // ── SOLICITAÇÕES PRESTADORES ──────────────────────────────────────
    match /solicitacoes_prestadores/{id} {
      allow create:       if true;
      allow read, update: if isGestorSeg();
      allow delete:       if isGestorSeg();
    }

    // ── OPERAÇÕES ─────────────────────────────────────────────────────
    match /operacoes/{id} {
      allow read, write: if isGestor() || hasRole(['logistica']);
    }

    // ── ROTAS ─────────────────────────────────────────────────────────
    match /rotas/{id} {
      allow read, write: if isGestor() || hasRole(['logistica']);
    }

    // ── SLOTS ─────────────────────────────────────────────────────────
    match /slots/{slotId} {
      allow read, write: if isGestor();
      allow read: if isPrestadorAtivo() &&
        resource.data.get('cidade', '') == getUser().get('cidade', '') &&
        resource.data.get('status', '') in ['aberto', 'Aberto'];
      allow read: if isPrestadorAtivo() &&
        resource.data.get('aceitoPor', '') == request.auth.uid;
      allow update: if isPrestadorAtivo() &&
        resource.data.get('status', '') == 'aberto' &&
        request.resource.data.aceitoPor == request.auth.uid;
      allow update: if isPrestadorAtivo() &&
        resource.data.get('aceitoPor', '') == request.auth.uid &&
        resource.data.get('status', '') in ['aceito', 'em_andamento'];
    }

    // ── SLOT ACEITES ──────────────────────────────────────────────────
    match /slot_aceites/{id} {
      allow read:  if isGestorSeg() || isPrestadorAtivo();
      allow write: if isGestorSeg() || isPrestadorAtivo();
    }

    // ── SLOT LEMBRETES / ALERTAS ──────────────────────────────────────
    match /slot_lembretes/{id} {
      allow read, write: if isGestor();
    }
    match /slot_alertas/{id} {
      allow read, write: if isGestor();
    }

    // ── TAREFAS ───────────────────────────────────────────────────────
    match /tarefas/{tarefaId} {
      allow read, write: if isGestor();
      allow read:   if isPrestadorAtivo() && resource.data.assigneeUid == request.auth.uid;
      allow update: if isPrestadorAtivo() && resource.data.assigneeUid == request.auth.uid &&
        request.resource.data.assigneeUid == request.auth.uid;
    }

    // ── TAREFAS LOGÍSTICA ─────────────────────────────────────────────
    match /tarefas_logistica/{id} {
      allow read, write: if isGestor() || isSuperGestor();
      allow read:   if isAtivo() && hasRole(['logistica', 'campo', 'promotor', 'charger', 'scalt']);
      allow update: if isAtivo() && hasRole(['logistica', 'campo', 'charger', 'scalt']) &&
        resource.data.assigneeUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'iniciadoEm', 'concluidoEm', 'fotoChegadaUrl',
                    'fotoConclusaoUrl', 'atualizadoEm', 'deliveredCount']);
      allow create: if isAtivo() && (isGestor() || request.resource.data.criadoPor == 'system');

      match /audit_log/{entryId} {
        allow read:   if isAtivo() && (isGestor() || isSuperGestor() ||
          hasRole(['logistica', 'campo', 'charger', 'scalt']));
        allow create: if isAtivo();
        allow update, delete: if false;
      }
    }

    // ── OCORRÊNCIAS ───────────────────────────────────────────────────
    match /ocorrencias/{id} {
      // Qualquer usuário autenticado pode ler e criar ocorrências
      // (guards no PWA/APK criam; admin/web lê tudo)
      allow read, create: if isAuth();

      // Atualizar: próprio guard ou gestor
      allow update: if isAuth() && (
        isGestorSeg() ||
        resource.data.registradoPor == request.auth.uid
      );

      // Deletar: só gestor
      allow delete: if isGestorSeg();

      // Guard/campo/prestador: cria própria ocorrência
      allow create: if isAuth() && (
        hasRole(['campo', 'guard', 'promotor', 'charger', 'scalt']) ||
        isPrestadorAtivo()
      );

      // Guard: atualiza própria ocorrência (foto, BO) mas não muda status/tipo
      allow update: if isAuth() &&
        resource.data.registradoPor == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'prioridade', 'tipo']);
    }

    // ── GUARD CONFIG (regiões, configurações painel) ──────────────────
    match /guard_config/{id} {
      allow read:  if isAtivo();
      allow write: if isGestorSeg();
    }

    // ── GPS LOGÍSTICA ─────────────────────────────────────────────────
    match /gps_logistica/{id} {
      allow read:   if isGestor();
      allow create: if isPrestadorAtivo() && request.resource.data.uid == request.auth.uid;
    }

    // GPS histórico (subcoleção)
    match /gps_logistica_hist/{uid}/pontos/{pontoId} {
      allow read:   if isGestor();
      allow create: if isAuth() && request.auth.uid == uid;
    }

    // ── GOJET SNAPSHOTS ───────────────────────────────────────────────
    match /gojet_snapshots/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isSuperGestor();
    }

    // ── GOJET PARKING HISTORY ────────────────────────────────────────
    match /parking_history/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isSuperGestor();
    }

    // ── LOG SLOTS AUTO ────────────────────────────────────────────────
    match /log_slots_auto/{id} {
      allow read:  if isGestor() || isSuperGestor();
      allow write: if isGestor() || isSuperGestor();
    }

    // ── OCORRÊNCIAS HISTÓRICO ─────────────────────────────────────────
    match /ocorrencias_historico/{id} {
      allow read:  if isGestorSeg();
      allow write: if isGestorSeg();
    }

    // ── TURNOS ────────────────────────────────────────────────────────
    match /turnos/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isSuperGestor() || isPrestadorAtivo();
    }

    // ── GOJET CONFIG ──────────────────────────────────────────────────
    match /gojet_config/{id} {
      allow read:  if isGestor() || isSuperGestor();
      allow write: if isAdmin() || isSuperGestor();
    }

    // ── MONITOR CONFIG (thresholds M1/M2/M3 por cidade) ──────────────
    match /monitor_config/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isSuperGestor();
    }

    // ── CONFIG LOGÍSTICA ─────────────────────────────────────────────
    match /config_logistica/{id} {
      allow read:  if isAtivo() && hasRole(['admin','gestor','supergestor','logistica']);
      allow write: if hasRole(['admin','gestor','supergestor']);
    }

    // ── PAGAMENTOS CONFIG (valor por tarefa por cidade) ───────────────
    match /pagamentos_config/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isSuperGestor();
    }

    // ── PAGAMENTOS SEMANA (registros semanais por prestador) ──────────
    match /pagamentos_semana/{id} {
      allow read:  if isAtivo() && (
        isGestor() || isSuperGestor() ||
        resource.data.uid == request.auth.uid
      );
      allow create: if isAtivo() && request.resource.data.uid == request.auth.uid;
      allow update: if isAtivo() && (
        isGestor() || isSuperGestor() ||
        (resource.data.uid == request.auth.uid && resource.data.status in ['aberto','rejeitada'])
      );
    }

    // ── NOTAS FISCAIS (storage paths validados via Storage Rules) ─────
    match /notas_fiscais/{id} {
      allow read:  if isAtivo() && (isGestor() || isSuperGestor() || resource.data.uid == request.auth.uid);
      allow write: if isAtivo() && request.resource.data.uid == request.auth.uid;
    }

    // ── ESCALA CONFIG / FERIADOS ──────────────────────────────────────
    match /escala_config/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }
    match /feriados/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── DISPONIBILIDADES (Slots & Teams) ──────────────────────────────
    match /disponibilidades/{id} {
      allow read:  if isGestor() || isPrestadorAtivo();
      allow write: if isGestor() || (isPrestadorAtivo() && resource.data.uid == request.auth.uid);
      allow create: if isPrestadorAtivo();
    }

    // ── PRESTADORES (ranking, gamificação) ───────────────────────────
    match /prestadores/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || request.auth.uid == id;
    }

    // ── PENALIDADES ───────────────────────────────────────────────────
    match /penalidades/{id} {
      allow read:  if isGestor() || (isAtivo() && resource.data.uid == request.auth.uid);
      allow write: if isGestor();
    }

    // ── EFICIÊNCIAS LOGÍSTICA ─────────────────────────────────────────
    match /eficiencias_logistica/{id} {
      allow read, write: if isGestor();
    }

    // ── MEIs ──────────────────────────────────────────────────────────
    match /meis/{id} {
      allow read:  if hasRole(['admin','gestor','supergestor','logistica']);
      allow write: if hasRole(['admin','gestor','supergestor']);
    }

    // ── INVENTÁRIO ────────────────────────────────────────────────────
    match /inventario_armario/{id}  { allow read, write: if isGestor(); }
    match /inventario_patinete/{id} { allow read, write: if isGestor(); }
    match /inventario_carro/{id}    { allow read, write: if isGestor(); }
    match /inventario_suporte/{id}  { allow read, write: if isGestor(); }

    // ── SLOT CONFIG ───────────────────────────────────────────────────
    match /slot_config/{id} {
      allow read:  if isGestor() || isSuperGestor();
      allow write: if isAdmin();
    }

    // ── TELEGRAM CONFIG ───────────────────────────────────────────────
    match /telegram_config/{id} {
      allow read, write: if isGestor();
    }

    // ── TELEGRAM VÍNCULOS ─────────────────────────────────────────────
    match /telegram_vinculos/{codigo} {
      allow read, write: if false; // somente via Cloud Function
    }

    // ── FCM TOKENS ───────────────────────────────────────────────────
    match /fcm_tokens/{id} {
      allow read, write: if isAuth() && request.auth.uid == id;
      allow read: if isGestor();
    }

    // ── TURNOS LOGÍSTICA ─────────────────────────────────────────────
    match /turnos_logistica/{id} {
      allow read:   if isGestor();
      allow create: if isPrestadorAtivo();
    }

    // ── LOGS AUTOMAÇÃO ────────────────────────────────────────────────
    match /logs_automacao/{id} {
      allow read: if isGestor() || isSuperGestor();
    }

    // ── SOLICITAÇÕES ──────────────────────────────────────────────────
    match /solicitacoes/{id} {
      allow read, write: if isGestor() || isCampo();
    }

    // ── POLÍGONOS ─────────────────────────────────────────────────────
    match /poligonos/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor() || isCampo();
    }

    // ── EVENTOS ───────────────────────────────────────────────────────
    match /eventos/{id} {
      allow read, write: if isAtivo();
    }

    // ── CONFIG ────────────────────────────────────────────────────────
    match /config/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── ANALYTICS ─────────────────────────────────────────────────────
    match /analytics_days/{id} {
      allow read, write: if isGestor();
    }

    // ── LOCAIS OPERACIONAIS ───────────────────────────────────────────
    match /locais_operacionais/{id} {
      allow read, write: if isAtivo();
    }

    // ── CIDADES EXPANSÃO ──────────────────────────────────────────────
    match /cidades_expansao/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── CACHE POIs ────────────────────────────────────────────────────
    match /pois_cache/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── CONTRATOS / PAGAMENTOS LOCAIS ─────────────────────────────────
    match /contratos_locais/{id} {
      allow read, write: if isGestor();
    }
    match /pagamentos_locais/{id} {
      allow read, write: if isGestor();
    }

    // ── TREINAMENTOS ──────────────────────────────────────────────────
    match /treinamentos/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }
    match /treinamento_progresso/{id} {
      allow read, write: if isAtivo();
    }

    // ── PRODUTIVIDADE ─────────────────────────────────────────────────
    match /produtividade/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── CIDADES ───────────────────────────────────────────────────────
    match /cidades/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── ZONAS ─────────────────────────────────────────────────────────
    match /zonas/{id} {
      allow read:  if isAtivo();
      allow write: if isGestor();
    }

    // ── GESTORES ──────────────────────────────────────────────────────
    match /gestores/{id} {
      allow read, write: if isGestor();
    }

    // ── GRUPOS TELEGRAM (legado) ──────────────────────────────────────
    match /gruposTelegram/{id} {
      allow read, write: if isGestor();
    }

    // ── TASKS ─────────────────────────────────────────────────────────
    match /tasks/{id} {
      allow read, write: if isAtivo();
    }

    // ── NOTIFICAÇÕES ──────────────────────────────────────────────────
    match /notificacoes/{id} {
      allow read, write: if isAtivo();
    }
    match /notificacoes_app/{id} {
      allow read, write: if isAtivo();
    }

    // ── HISTÓRICO ALTERAÇÕES ──────────────────────────────────────────
    match /historico_alteracoes/{id} {
      allow read, write: if isGestor();
    }

    // ── SLOTS FEEDBACKS ───────────────────────────────────────────────
    match /slots_feedbacks/{fbId} {
      allow read:   if isGestor();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

  }
}
